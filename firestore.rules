rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isCoach() {
      return isSignedIn() && (getUserRole() == 'coach' || getUserRole() == 'admin');
    }

    function isLinkedPlayer(playerId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedPlayerId == playerId;
    }

    // ─── Users ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isCoach());
      allow create: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }


    // ─── Invites ──────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email &&
         request.resource.data.claimed == true);
      allow delete: if isAdmin();
    }

    // ─── Players ────────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isCoach();

      // Sub-collections (maxEntries, combineResults, gameStats)
      match /{subcollection}/{docId} {
        allow read: if isSignedIn() && (isLinkedPlayer(playerId) || isCoach());
        allow write: if isCoach();
      }
    }

    // ─── Player Preferences ─────────────────────────────────
    match /playerPreferences/{playerId} {
      allow read: if isSignedIn() && (isLinkedPlayer(playerId) || isCoach());
      allow write: if isSignedIn() && isLinkedPlayer(playerId);
    }

    // ─── Coaches ────────────────────────────────────────────
    match /coaches/{coachId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Games ──────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Calendar Events ────────────────────────────────────
    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Workout Programs ───────────────────────────────────
    match /workoutPrograms/{programId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Announcements ──────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Recruiting Profiles ────────────────────────────────
    match /recruitingProfiles/{playerId} {
      allow read: if isSignedIn() && (isLinkedPlayer(playerId) || isCoach());
      allow write: if isSignedIn() && (isLinkedPlayer(playerId) || isCoach());
    }

    // ─── Depth Charts ───────────────────────────────────────
    match /depthCharts/{chartId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Game Awards ────────────────────────────────────────
    match /gameAwards/{awardId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Hudl Films ─────────────────────────────────────────
    match /hudlFilms/{filmId} {
      allow read: if isSignedIn();
      allow write: if isCoach();

      // Play breakdown sub-collection
      match /plays/{playId} {
        allow read: if isSignedIn();
        allow write: if isCoach();
      }
    }

    // ─── Hudl Player Stats ────────────────────────────────────
    match /hudlPlayerStats/{statId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ─── Agent Sessions (analytics) ─────────────────────────
    match /agentSessions/{sessionId} {
      allow read: if isCoach();
      allow create: if isSignedIn();
    }

    // ─── Analytics ──────────────────────────────────────────
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write analytics
    }

    // ─── Player Chat (E2E Encrypted) ──────────────────────
    function isPlayerRole() {
      return isSignedIn() && getUserRole() == 'player';
    }

    match /chatRooms/{roomId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;

      allow create: if isPlayerRole() &&
        request.auth.uid in request.resource.data.participantUids &&
        request.resource.data.participantUids.size() >= 2 &&
        request.resource.data.participantUids.size() <= 50;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantUids;

        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantUids &&
          request.resource.data.senderUid == request.auth.uid;

        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
